<!DOCTYPE html>
<html lang="en">
<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Echo Minds</title>

<link rel="stylesheet" href="style.css">

<link rel="stylesheet"
href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">

</head>

<body>

<div class="container" id="container">

<!-- LOGIN PANEL -->

<div class="panel active" id="loginPanel">

<h1>Echo Minds</h1>
<h3>Login</h3>

<input type="text" id="username" placeholder="Username">
<input type="password" id="password" placeholder="Password">

<button onclick="login()">Login</button>

<p id="loginError"></p>

</div>


<!-- HOME PANEL -->

<div class="panel" id="homePanel">

<h1>Echo Minds</h1>

<div class="options">

<div class="card" onclick="showChat()">
<i class="fa-solid fa-comments"></i>
<p>Chat Box</p>
</div>

<div class="card" onclick="showTracker()">
<i class="fa-solid fa-heart"></i>
<p>Habit Tracker</p>
</div>

</div>

</div>


<!-- CHAT PANEL -->

<div class="panel" id="chatPanel">

<button class="back-btn" onclick="goHome()">← Back</button>

<h2>Echo Minds Chat</h2>

<div class="chat-box" id="chatBox"></div>

<div class="input-area">

<input type="text" id="userInput"
placeholder="How are you feeling today?">

<button onclick="sendMessage()">Send</button>

</div>

</div>


<!-- UPDATED TRACKER PANEL -->

<div class="panel" id="trackerPanel">

<button class="back-btn" onclick="goHome()">← Back</button>

<h2>Daily Habit Tracker</h2>

<label>Mood</label>
<select id="mood">
<option>Happy</option>
<option>Calm</option>
<option>Neutral</option>
<option>Sad</option>
<option>Stressed</option>
</select>

<label>Sleep Hours</label>
<input type="number" id="sleep" min="0" max="24">

<label>Water Intake (glasses)</label>
<input type="number" id="water" min="0">

<label>Workout / Walk (minutes)</label>
<input type="number" id="workout" min="0">

<label>Screen Time (hours)</label>
<input type="number" id="screen" min="0">





<label>Daily Reflection</label>
<textarea id="reflection" placeholder="How was your day?"></textarea>

<button onclick="saveActivity()">Save</button>

<div id="saveStatus"></div>

<div id="scoreDisplay"></div>

</div>


</div>
<!-- LOGOUT BUTTON -->

<button id="logoutBtn" onclick="logout()">Logout</button>

<script src="script.js"></script>

</body>
</html>
